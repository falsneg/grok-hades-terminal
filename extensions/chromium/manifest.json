{
  "manifest_version": 3,
  "name": "Hades Terminal",
  "version": "1.0.0",
  "author": "falsneg",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "description": "A UI wrapper for Grok's command/code execution sandbox.",
  "content_scripts": [
    {
      "matches": ["*://grok.com/*", "*://*.grok.com/*"],
      "js": ["hades.js"],
      "run_at": "document_idle"
    }
  ]
}
